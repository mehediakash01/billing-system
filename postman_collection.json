{
  "info": {
    "name": "SaaS Subscription Billing System Engine",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Register Account client",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"client\"\n}"
        },
        "url": { "raw": "http://localhost:5000/api/v1/auth/register" }
      }
    },
    {
      "name": "Authenticate Login Session",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"jane@example.com\",\n  \"password\": \"password123\"\n}"
        },
        "url": { "raw": "http://localhost:5000/api/v1/auth/login" }
      }
    },
    {
      "name": "Purchase Subscription Active Tier",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer <PLACE_YOUR_JWT_TOKEN_HERE>" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"planId\": \"650c1f2e4f1a2c3d4e5f6a7b\",\n  \"autoRenew\": true\n}"
        },
        "url": { "raw": "http://localhost:5000/api/v1/subscriptions/purchase" }
      }
    },
    {
      "name": "Create Subscription Plan",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer <ADMIN_JWT_TOKEN>" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Premium\",\n  \"price\": 99,\n  \"durationInDays\": 30,\n  \"isActive\": true\n}"
        },
        "url": { "raw": "http://localhost:5000/api/v1/plans" }
      }
    },
    {
      "name": "Cancel Subscription",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer <CLIENT_JWT_TOKEN>" }
        ],
        "url": { "raw": "http://localhost:5000/api/v1/subscriptions/<SUBSCRIPTION_ID>/cancel" }
      }
    },
    {
      "name": "Payment Webhook Update",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "x-webhook-signature", "value": "<HMAC_SHA256_SIGNATURE>" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"event\": \"payment.succeeded\",\n  \"data\": {\n    \"subscriptionId\": \"<SUBSCRIPTION_ID>\"\n  }\n}"
        },
        "url": { "raw": "http://localhost:5000/api/v1/webhooks/payment-update" }
      }
    }
  ]
}